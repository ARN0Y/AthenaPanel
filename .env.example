# ==========================================================================
# AthenaPanel environment — copy to .env and edit. The installer reads this.
# PostgreSQL + TimescaleDB backend; L2TP/IPsec + SSTP + WireGuard stack.
# Real secrets belong ONLY in .env (gitignored) or the backup bundle.
# ==========================================================================

# --- Admin panel login (bootstrap superadmin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- JWT --- (generate with: openssl rand -hex 32)
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_EXPIRE_HOURS=24

# --- Database (production) ---
# Empty -> legacy local SQLite (VPN_DB_PATH). Production uses PostgreSQL:
DATABASE_URL=postgresql+asyncpg://vpnpanel:change-me-db-pass@127.0.0.1:5432/vpnpanel

# --- IPsec (must match what the VPN core / clients use) ---
VPN_PSK=change-me-strong-preshared-key

# --- First VPN user created by the core installer (optional) ---
VPN_USER=change-me
VPN_PASSWORD=change-me

# --- Network (informational for the panel UI) ---
WAN_IFACE=eth0
PPP_LOCAL_IP=192.168.42.1
PPP_POOL=192.168.42.10-192.168.42.250

# --- Panel ---
PANEL_PORT=80
# Secret URL prefix the panel is served under (bare IP returns 444).
PANEL_PATH=/admin-athena

# --- Client-facing profile (editable later in Settings > Server) ---
SERVER_ADDRESS=lttp.example.com     # L2TP/IPsec endpoint (your entry domain)
SSTP_ADDRESS=sstp.example.com       # SSTP (https/443) endpoint
SSTP_ENABLED=false                  # set true after setup-sstp.sh

# --- Backhaul mode (entry node -> this server over a TUN tunnel) ---
# Local TUN address IPsec packets actually arrive on; installer points
# Libreswan's `left` at it. Empty for direct-to-public-IP setups.
BACKHAUL_ADDR=10.50.50.1

# --- Paths (rarely changed) ---
CHAP_SECRETS=/etc/ppp/chap-secrets
CHAP_SERVER_FIELD=*
ACCT_LOG=/var/log/vpn-panel/accounting.log
VPN_DB_PATH=/var/lib/vpn-panel/vpn.db

# --- Backend bind (uvicorn, loopback only) ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Quota enforcement poll interval (seconds) ---
QUOTA_POLL_SECONDS=30
