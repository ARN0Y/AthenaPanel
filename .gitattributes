# The whole project targets Linux — force LF everywhere so scripts, unit files
# and configs run correctly no matter which OS edits/commits them. Without this,
# a Windows checkout commits CRLF and the .sh installers break on the server
# with `$'\r': command not found`.
* text=auto eol=lf

*.sh      text eol=lf
*.service text eol=lf
*.conf    text eol=lf
*.toml    text eol=lf
*.py      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.env.example text eol=lf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
